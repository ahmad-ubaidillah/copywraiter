# ── App ──────────────────────────────────────────────────────────
APP_NAME=copywrAIter
DEBUG=false
SECRET_KEY=change-me-in-production

# ── Database (SQLite — local-first for VPS portability) ──────────
DATABASE_URL=sqlite:///./data/app.db

# ── AI Providers ─────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Custom Provider (Hermes-compatible / OpenAI-compatible) ──────
# Any OpenAI-compatible endpoint: OpenRouter, Together, Groq, DeepSeek, etc.
# Examples:
#   OpenRouter:  https://openrouter.ai/api/v1
#   Together AI: https://api.together.xyz/v1
#   Groq:        https://api.groq.com/openai/v1
#   DeepSeek:    https://api.deepseek.com/v1
#   Fireworks:   https://api.fireworks.ai/inference/v1
#   Mistral:     https://api.mistral.ai/v1
#   Gemini:      https://generativelanguage.googleapis.com/v1beta/openai
#   xAI/Grok:    https://api.x.ai/v1
#   Ollama:      http://localhost:11434/v1
#   LM Studio:   http://localhost:1234/v1
AI_CUSTOM_BASE_URL=

# ── AI Model Defaults ────────────────────────────────────────────
AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-4o
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=4096

# ── Server ───────────────────────────────────────────────────────
PORT=8080

# ── Distribution (Repliz API) ────────────────────────────────────
REPLIZ_API_KEY=
REPLIZ_BASE_URL=
