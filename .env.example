# copywrAIter — Environment Variables
# Copy ke .env dan isi nilai-nilainya.

# Flask
FLASK_SECRET_KEY=ubah-ini-pake-string-random

# OpenAI (untuk generate copy)
OPENAI_API_KEY=sk-...

# LinkedIn API (https://www.linkedin.com/developers/)
LINKEDIN_CLIENT_ID=...
LINKEDIN_CLIENT_SECRET=...
LINKEDIN_REDIRECT_URI=http://localhost:5000/api/linkedin/callback

# Instagram (untuk Threads browser automation - opsional)
INSTAGRAM_USERNAME=...
INSTAGRAM_PASSWORD=...

# App
APP_ENV=development
DATABASE_PATH=data/app.db
LOG_LEVEL=INFO
